---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, getLocalizedPath, locales } from '../i18n/utils';
import { languages } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, canonical, noindex = false, ogImage } = Astro.props;
const site      = Astro.site ?? new URL('https://bmiresult.com');
const url       = canonical ? new URL(canonical, site) : new URL(Astro.url.pathname, site);
const fullTitle = title.includes('Real BMI') ? title : `${title} | BMI Result`;
const gaId      = 'G-MJ4MPYMNS7';
const adPubId   = import.meta.env.PUBLIC_ADSENSE_PUB_ID;
const lang      = getLangFromUrl(Astro.url);

const ogImageUrl = ogImage
  ? new URL(ogImage, site).href
  : new URL('/images/og-default.png', site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />

    {/* hreflang alternates — critical for multilingual SEO */}
    {locales.map((l) => (
      <link
        rel="alternate"
        hreflang={l === 'en' ? 'en-US' : l === 'hi' ? 'hi-IN' : l === 'es' ? 'es-ES' : 'fr-FR'}
        href={new URL(getLocalizedPath(l, Astro.url.pathname), site).href}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath('en', Astro.url.pathname), site).href} />

    {/* Open Graph */}
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={url.href} />
    <meta property="og:type"        content="website" />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name"   content="BMI Result" />

    {/* Twitter / X */}
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    <title>{fullTitle}</title>

    {/* Force light mode as default — user can override with Dark button */}
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('rbmi-theme');
        // Only apply dark if user explicitly chose it — default is always light
        if (stored === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>

    {/* Google Analytics 4 — G-MJ4MPYMNS7 */}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MJ4MPYMNS7"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MJ4MPYMNS7');
    </script>

    {/* Google AdSense — activated once PUBLIC_ADSENSE_PUB_ID is set */}
    {adPubId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adPubId}`}
        crossorigin="anonymous"
      ></script>
    )}

    <slot name="head" />

    {/* Print styles */}
    <style>
      @media print {
        header, footer, #cookie-banner, #share-panel, #copy-result,
        .print-hide, [data-nudge], .preset-chip, #unit-toggle,
        #height-metric input[type=range], #height-us input[type=range],
        #body-model-container, #history-panel, .bmi-range { display: none !important; }
        body { background: white !important; color: black !important; }
        #result-panel, #bmi-value, #bmi-category { display: block !important; }
        #bmi-marker { display: none !important; }
        .print-brand::after { content: " — bmiresult.com"; font-size: 0.75rem; color: #666; }
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Header lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    {/* Cookie consent banner */}
    <div
      id="cookie-banner"
      role="dialog"
      aria-label="Cookie notice"
      class="fixed bottom-0 left-0 right-0 z-50 hidden border-t border-(--color-hairline) bg-(--color-surface)/95 px-4 py-4 shadow-xl backdrop-blur-sm sm:px-6"
    >
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4">
        <p class="text-sm text-(--color-body) max-w-2xl">
          We use cookies for site preferences and, once enabled, Google AdSense to serve
          relevant ads. No personal data is sold.
          <a href="/privacy-policy" class="underline text-(--color-link)">Learn more</a>.
        </p>
        <div class="flex gap-3 shrink-0">
          <button
            id="cookie-decline"
            class="rounded-lg border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-sm font-medium text-(--color-body) hover:border-(--color-accent) transition"
          >
            Decline
          </button>
          <button
            id="cookie-accept"
            class="rounded-lg bg-(--color-accent) px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition"
          >
            Accept
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var CONSENT_KEY = 'rbmi-cookie-consent';
        var banner = document.getElementById('cookie-banner');
        if (!banner) return;
        if (!localStorage.getItem(CONSENT_KEY)) {
          setTimeout(function () { banner.classList.remove('hidden'); }, 800);
        }
        function dismiss(accepted) {
          localStorage.setItem(CONSENT_KEY, accepted ? 'accepted' : 'declined');
          banner.classList.add('hidden');
        }
        document.getElementById('cookie-accept')?.addEventListener('click', function () { dismiss(true); });
        document.getElementById('cookie-decline')?.addEventListener('click', function () { dismiss(false); });
      })();
    </script>
  </body>
</html>