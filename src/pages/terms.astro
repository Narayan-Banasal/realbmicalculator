---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProsePage from '../components/ProsePage.astro';
---

<BaseLayout appendBrand={true}
  title="Terms of Service"
  description="Terms of Service for using BMI Result and bmiresult.com."
>
  <ProsePage title="Terms of Service" lead="Last updated: June 2026">
    <p>
      By using BMI Result you agree to these terms. If you do not agree, please do not use the site.
    </p>
    <h2 class="font-display text-xl font-semibold text-(--color-ink)">Not medical advice</h2>
    <p>
      The BMI calculator and articles are for informational purposes only. They do not create a
      doctor-patient relationship. Always seek professional advice for medical decisions.
    </p>
    <h2 class="font-display text-xl font-semibold text-(--color-ink)">Accuracy</h2>
    <p>
      We strive for accurate formulas and content but provide the site “as is” without warranties. We are not
      liable for damages arising from use of the site.
    </p>
    <h2 class="font-display text-xl font-semibold text-(--color-ink)">Intellectual property</h2>
    <p>
      Site design and original text are owned by BMI Result. You may link to our pages with
      attribution.
    </p>
  </ProsePage>
</BaseLayout>