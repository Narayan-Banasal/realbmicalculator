---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProsePage from '../components/ProsePage.astro';
---

<BaseLayout
  title="About Us"
  description="About BMI Result — a free, accurate body mass index tool built for clarity and SEO-friendly health education."
>
  <ProsePage title="About BMI Result" lead="We help people understand their body mass index with a fast, honest, mobile-first calculator.">
    <p>
      BMI Result (bmiresult.com) is an independent health utility site. We are not a
      hospital, insurer, or government agency. Our goal is to provide a better user experience than legacy
      calculator pages: instant BMI results, accessible design, dark mode, and clear educational content.
    </p>
    <p>
      Content on this site is written for adults in the United States and internationally who search for
      “BMI calculator” and related terms. We cite standard WHO adult BMI categories and encourage users to
      consult healthcare professionals for personal decisions.
    </p>
    <p>
      Questions? Visit our <a href="/contact" class="text-(--color-link) hover:underline">contact page</a>.
    </p>
  </ProsePage>
</BaseLayout>