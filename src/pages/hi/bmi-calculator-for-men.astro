---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BmiCalculator from '../../components/BmiCalculator.astro';
const lang = 'hi';
---
<BaseLayout title="पुरुषों के लिए BMI कैलकुलेटर | BMI Result" description="पुरुषों के लिए BMI कैलकुलेटर। मांसपेशी, वसा, और ऊंचाई के आधार पर स्वस्थ वजन सीमा।">
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <h1 class="font-display text-3xl font-bold text-(--color-ink)">पुरुषों के लिए BMI कैलकुलेटर</h1>
    <p class="mt-3 text-lg text-(--color-body)">
      पुरुषों में मांसपेशियां अधिक होती हैं, जो BMI को प्रभावित कर सकती हैं। एथलीट और बॉडीबिल्डर
      का BMI अधिक हो सकता है, भले ही उनकी शरीर वसा कम हो।
    </p>
    <div class="mt-8"><BmiCalculator lang={lang} /></div>
    <article class="mt-12 space-y-4 text-(--color-body)">
      <h2 class="font-display text-2xl font-semibold text-(--color-ink)">पुरुषों में BMI की विशेष बातें</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li>पुरुषों में उच्च मांसपेशी द्रव्यमान BMI को अधिक दिखा सकता है — यह हमेशा अस्वस्थ नहीं है।</li>
        <li>पेट की चर्बी (>94cm कमर) स्वास्थ्य के लिए अधिक जोखिम भरी होती है।</li>
        <li>40 वर्ष से अधिक आयु के पुरुषों को हृदय स्वास्थ्य के लिए अन्य संकेतकों की भी जांच करनी चाहिए।</li>
      </ul>
    </article>
  </div>
</BaseLayout>
