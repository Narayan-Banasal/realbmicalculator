---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BmiCalculator from '../../components/BmiCalculator.astro';
import FaqSection from '../../components/FaqSection.astro';

const lang = 'hi';
const title = 'BMI कैलकुलेटर — फ्री बॉडी मास इंडेक्स टूल';
const description = 'मुफ्त BMI कैलकुलेटर। अपनी ऊंचाई और वजन दर्ज करें और तुरंत अपना बॉडी मास इंडेक्स जानें। किग्रा, पाउंड या स्टोन में काम करता है।';
---

<BaseLayout title={title} description={description}>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "BMI Calculator",
      "url": new URL(Astro.url.pathname, Astro.site).href,
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Any",
      "browserRequirements": "Requires JavaScript",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
  </Fragment>

  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <section class="mb-10 max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-wider text-(--color-accent-deep)">bmiresult.com</p>
      <h1 class="font-display mt-2 text-4xl font-bold tracking-tight text-(--color-ink) sm:text-5xl">
        BMI कैलकुलेटर
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-(--color-body)">
        अपनी ऊंचाई और वजन दर्ज करें — BMI तुरंत अपडेट होगा। किग्रा, पाउंड, या स्टोन में काम करता है।
        परिणाम में श्रेणी, स्वस्थ वजन सीमा, आदर्श वजन और शरीर का 3D मॉडल शामिल है।
      </p>
    </section>

    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:gap-12">
      <BmiCalculator lang={lang} />
      <aside class="space-y-6 text-sm leading-relaxed text-(--color-body) lg:sticky lg:top-24 lg:self-start">
        <div class="rounded-xl border border-(--color-hairline) bg-(--color-accent)/5 p-5">
          <h2 class="font-semibold text-(--color-ink)">BMI श्रेणियां (वयस्क)</h2>
          <table class="mt-3 w-full text-left text-sm">
            <thead>
              <tr class="border-b border-(--color-hairline) text-(--color-mute)">
                <th class="py-2 pr-2">श्रेणी</th>
                <th class="py-2">BMI (kg/m²)</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-(--color-hairline)/60"><td class="py-2">कम वजन</td><td>&lt; 18.5</td></tr>
              <tr class="border-b border-(--color-hairline)/60"><td class="py-2">सामान्य</td><td>18.5 – 24.9</td></tr>
              <tr class="border-b border-(--color-hairline)/60"><td class="py-2">अधिक वजन</td><td>25 – 29.9</td></tr>
              <tr><td class="py-2">मोटापा</td><td>≥ 30</td></tr>
            </tbody>
          </table>
        </div>

        <div class="rounded-xl border border-(--color-hairline) bg-(--color-canvas) p-5">
          <h2 class="font-semibold text-(--color-ink) mb-3">संबंधित टूल्स</h2>
          <ul class="space-y-2 text-sm">
            <li><a href="/hi/bmi-chart" class="flex items-center gap-2 text-(--color-link) hover:underline"><span>📊</span> BMI चार्ट</a></li>
            <li><a href="/hi/bmi-calculator-for-women" class="flex items-center gap-2 text-(--color-link) hover:underline"><span>♀️</span> महिलाओं के लिए BMI</a></li>
            <li><a href="/hi/bmi-calculator-for-men" class="flex items-center gap-2 text-(--color-link) hover:underline"><span>♂️</span> पुरुषों के लिए BMI</a></li>
            <li><a href="/bmi-calculator-for-children" class="flex items-center gap-2 text-(--color-link) hover:underline"><span>👶</span> बच्चों के लिए BMI</a></li>
          </ul>
        </div>

        <p><strong class="text-(--color-ink)">चिकित्सा अस्वीकरण:</strong> यह टूल पेशेवर चिकित्सा सलाह का विकल्प नहीं है।</p>
      </aside>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <article class="prose-section mx-auto mt-16 max-w-3xl space-y-6 text-(--color-body)">
      <h2 class="font-display text-2xl font-semibold text-(--color-ink)">BMI क्या है?</h2>
      <p>
        बॉडी मास इंडेक्स (BMI) एक साधारण गणना है जो व्यक्ति की ऊंचाई और वजन का उपयोग करती है।
        WHO और CDC जैसे स्वास्थ्य संगठन वजन से संबंधित स्वास्थ्य जोखिमों की जांच के लिए BMI का उपयोग करते हैं।
      </p>
      <p>
        सूत्र: <strong>BMI = वजन (kg) ÷ ऊंचाई² (m)</strong>
      </p>
      <h2 class="font-display text-2xl font-semibold text-(--color-ink)">BMI की सीमाएं</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><strong>एथलीट:</strong> BMI मांसपेशी और वसा में अंतर नहीं कर सकता।</li>
        <li><strong>आयु:</strong> वृद्ध वयस्कों के लिए थोड़ा अधिक BMI (22-27) सुरक्षात्मक हो सकता है।</li>
        <li><strong>जातीयता:</strong> एशियाई लोगों के लिए WHO ने कम थ्रेशोल्ड (23/27.5) की सिफारिश की है।</li>
      </ul>
    </article>
    <div class="mx-auto mt-16 max-w-3xl">
      <FaqSection />
    </div>
  </div>
</BaseLayout>
