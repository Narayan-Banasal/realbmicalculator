---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BmiCalculator from '../../components/BmiCalculator.astro';
const lang = 'hi';
---
<BaseLayout title="महिलाओं के लिए BMI कैलकुलेटर | BMI Result" description="महिलाओं के लिए BMI कैलकुलेटर। WHO श्रेणियां, स्वस्थ वजन सीमा, और शरीर वसा अनुमान।">
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <h1 class="font-display text-3xl font-bold text-(--color-ink)">महिलाओं के लिए BMI कैलकुलेटर</h1>
    <p class="mt-3 text-lg text-(--color-body)">
      महिलाओं के लिए BMI की व्याख्या पुरुषों से थोड़ी अलग हो सकती है। मांसपेशी और वसा का अनुपात,
      हड्डियों का घनत्व, और गर्भावस्था — ये सभी BMI रीडिंग को प्रभावित कर सकते हैं।
    </p>
    <div class="mt-8"><BmiCalculator lang={lang} /></div>
    <article class="mt-12 space-y-4 text-(--color-body)">
      <h2 class="font-display text-2xl font-semibold text-(--color-ink)">महिलाओं में BMI की विशेष बातें</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li>महिलाओं में पुरुषों की तुलना में स्वाभाविक रूप से अधिक शरीर वसा होती है — यह सामान्य है।</li>
        <li>18.5–24.9 का BMI स्वस्थ माना जाता है, लेकिन एथलेटिक महिलाओं में यह भिन्न हो सकता है।</li>
        <li>गर्भावस्था के दौरान BMI लागू नहीं होता — प्रसव पूर्व BMI का उपयोग करें।</li>
        <li>रजोनिवृत्ति के बाद शरीर की संरचना बदल सकती है — कमर की माप भी जांचें।</li>
      </ul>
    </article>
  </div>
</BaseLayout>
