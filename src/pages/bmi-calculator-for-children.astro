---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Child BMI Calculator — BMI Percentile for Kids"
  description="Free BMI calculator for children and teenagers ages 2–20. Uses CDC growth charts to show BMI percentile and weight category. Separate results for boys and girls."
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "BMI Calculator",
      "url": new URL(Astro.url.pathname, Astro.site).href,
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Any",
      "browserRequirements": "Requires JavaScript",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
  </Fragment>

  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <section class="mb-8 max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-wider text-(--color-accent-deep)">bmiresult.com</p>
      <h1 class="font-display mt-2 text-3xl font-bold tracking-tight text-(--color-ink) sm:text-4xl">
        BMI Calculator for Children & Teens
      </h1>
      <p class="mt-3 text-lg leading-relaxed text-(--color-body)">
        BMI for children uses <strong>age- and sex-specific percentiles</strong>, not the adult thresholds (18.5/25/30).
        This calculator uses CDC growth chart data for ages 2–20.
      </p>
    </section>

    {/* ── Calculator UI ─── */}
    <div id="child-calculator" class="rounded-2xl border border-(--color-hairline) bg-(--color-surface) p-5 shadow-sm sm:p-8">
      <div class="grid gap-5 sm:grid-cols-2">
        {/* Age */}
        <div>
          <label for="child-age" class="block text-sm font-medium text-(--color-body)">
            Age (years) <span class="text-red-500">*</span>
          </label>
          <input type="number" id="child-age" min="2" max="20" placeholder="e.g. 10" autocomplete="off"
            class="mt-1 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-4 py-3 outline-none focus:border-(--color-accent) focus:ring-2 focus:ring-(--color-accent)/20" />
        </div>

        {/* Sex */}
        <div>
          <fieldset>
            <legend class="text-sm font-medium text-(--color-body)">Sex <span class="text-red-500">*</span></legend>
            <div class="mt-2 flex gap-2">
              <label class="flex flex-1 cursor-pointer items-center justify-center rounded-xl border border-(--color-hairline) px-3 py-3 has-checked:border-(--color-accent) has-checked:bg-(--color-accent)/10">
                <input type="radio" name="child-gender" value="male" class="sr-only" checked />
                <span class="text-sm">♂ Boy</span>
              </label>
              <label class="flex flex-1 cursor-pointer items-center justify-center rounded-xl border border-(--color-hairline) px-3 py-3 has-checked:border-(--color-accent) has-checked:bg-(--color-accent)/10">
                <input type="radio" name="child-gender" value="female" class="sr-only" />
                <span class="text-sm">♀ Girl</span>
              </label>
            </div>
          </fieldset>
        </div>

        {/* Height */}
        <div>
          <label class="block text-sm font-medium text-(--color-body) mb-1">Height</label>
          <div class="flex gap-2">
            <div class="flex-1">
              <label for="child-height-ft" class="text-xs text-(--color-mute)">Feet</label>
              <input type="number" id="child-height-ft" min="2" max="7" value="4" autocomplete="off"
                class="mt-0.5 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-3 py-2.5 text-lg" />
            </div>
            <div class="flex-1">
              <label for="child-height-in" class="text-xs text-(--color-mute)">Inches</label>
              <input type="number" id="child-height-in" min="0" max="11" value="6" autocomplete="off"
                class="mt-0.5 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-3 py-2.5 text-lg" />
            </div>
            <div class="flex-none w-20">
              <label for="child-height-cm" class="text-xs text-(--color-mute)">cm</label>
              <input type="number" id="child-height-cm" min="50" max="220" value="137" autocomplete="off"
                class="mt-0.5 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-3 py-2.5 text-lg" />
            </div>
          </div>
        </div>

        {/* Weight */}
        <div>
          <label class="block text-sm font-medium text-(--color-body) mb-1">Weight</label>
          <div class="flex gap-2">
            <div class="flex-1">
              <label for="child-weight-kg" class="text-xs text-(--color-mute)">kg</label>
              <input type="number" id="child-weight-kg" min="5" max="200" step="0.1" value="32" autocomplete="off"
                class="mt-0.5 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-3 py-2.5 text-lg" />
            </div>
            <div class="flex-1">
              <label for="child-weight-lb" class="text-xs text-(--color-mute)">lb</label>
              <input type="number" id="child-weight-lb" min="10" max="440" step="0.1" value="70.5" autocomplete="off"
                class="mt-0.5 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-3 py-2.5 text-lg" />
            </div>
          </div>
        </div>
      </div>

      <button type="button" id="child-calc-btn"
        class="mt-6 w-full rounded-xl bg-(--color-accent) px-6 py-3.5 text-base font-semibold text-white transition hover:opacity-90">
        Calculate BMI Percentile
      </button>

      {/* Result */}
      <div id="child-result" class="hidden mt-8 rounded-xl border border-(--color-hairline) bg-(--color-canvas) p-6">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-sm text-(--color-mute) uppercase tracking-wide">BMI</p>
            <p id="child-bmi-value" class="font-display text-5xl font-bold tabular-nums text-(--color-ink)">—</p>
          </div>
          <div class="text-right">
            <p class="text-sm text-(--color-mute)">Percentile</p>
            <p id="child-percentile" class="text-3xl font-bold text-(--color-ink)">—</p>
          </div>
          <span id="child-category" class="w-full rounded-full px-4 py-1.5 text-sm font-semibold text-white text-center"></span>
        </div>

        {/* Percentile bar */}
        <div class="mt-6">
          <div class="relative h-4 overflow-hidden rounded-full bg-(--color-hairline)">
            <div class="absolute inset-0 flex">
              <div class="h-full bg-blue-400" style="width:5%"></div>
              <div class="h-full bg-emerald-400" style="width:80%"></div>
              <div class="h-full bg-amber-400" style="width:10%"></div>
              <div class="h-full bg-red-500 flex-1"></div>
            </div>
            <div id="child-marker"
              class="absolute top-1/2 h-6 w-6 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-(--color-ink) shadow-lg transition-all duration-500"
              style="left:0%">
            </div>
          </div>
          <div class="mt-1 flex justify-between text-[10px] text-(--color-mute)">
            <span>5th</span><span>15th</span><span>50th</span><span>85th</span><span>95th</span>
          </div>
        </div>

        <ul id="child-details" class="mt-5 space-y-1.5 text-sm text-(--color-body)"></ul>

        <div class="mt-5 rounded-xl bg-amber-50 dark:bg-amber-950/20 border border-amber-200/60 dark:border-amber-800/40 px-4 py-3">
          <p class="text-xs text-amber-700 dark:text-amber-300">
            <strong>⚠️ Medical disclaimer:</strong> This calculator provides an estimate based on CDC growth chart data.
            BMI percentile alone does not diagnose obesity or determine health risk in children.
            Always consult a pediatrician for a clinical assessment.
            <a href="https://www.cdc.gov/bmi/child-teen-calculator/index.html" target="_blank" rel="noopener" class="underline ml-1">
              Use the official CDC calculator →
            </a>
          </p>
        </div>
      </div>
    </div>

    {/* Education */}
    <article class="mt-14 max-w-3xl space-y-6 text-(--color-body)">
      <h2 class="font-display text-2xl font-semibold text-(--color-ink)">How BMI works differently for children</h2>
      <p>
        For adults, a single BMI threshold (18.5/25/30) applies to everyone. For <strong>children and teens ages 2–20</strong>,
        the same BMI value may mean very different things depending on age and sex, because children grow rapidly
        and body fatness changes significantly with age.
      </p>
      <p>
        Instead of fixed cut-points, children's BMI is expressed as a <strong>percentile</strong> compared
        to children of the same age and sex from the CDC's 2000 growth charts (the US reference population).
      </p>
      <div class="overflow-x-auto rounded-xl border border-(--color-hairline)">
        <table class="w-full text-sm">
          <thead class="bg-(--color-canvas)">
            <tr>
              <th class="p-3 text-left">Weight Category</th>
              <th class="p-3 text-left">BMI-for-Age Percentile Range</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-t border-(--color-hairline)">
              <td class="p-3 font-medium text-blue-600 dark:text-blue-400">Underweight</td>
              <td class="p-3">Below the 5th percentile</td>
            </tr>
            <tr class="border-t border-(--color-hairline)">
              <td class="p-3 font-medium text-emerald-600 dark:text-emerald-400">Healthy weight</td>
              <td class="p-3">5th percentile to less than the 85th percentile</td>
            </tr>
            <tr class="border-t border-(--color-hairline)">
              <td class="p-3 font-medium text-amber-600 dark:text-amber-400">Overweight</td>
              <td class="p-3">85th percentile to less than the 95th percentile</td>
            </tr>
            <tr class="border-t border-(--color-hairline)">
              <td class="p-3 font-medium text-red-600 dark:text-red-400">Obese</td>
              <td class="p-3">95th percentile or above</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="font-display text-2xl font-semibold text-(--color-ink)">Important considerations for children</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><strong>BMI is a screening tool, not a diagnosis.</strong> A child with a high BMI does not necessarily have excess body fat — it needs to be evaluated with a physical examination.</li>
        <li><strong>Growth spurts matter.</strong> A child's BMI can fluctuate significantly during puberty. A single measurement tells only part of the story.</li>
        <li><strong>Talk to your pediatrician</strong> before making dietary or activity changes based on BMI alone.</li>
        <li><strong>Healthy habits matter more than numbers.</strong> Regular physical activity (60 min/day) and a balanced diet are beneficial for all children, regardless of BMI.</li>
      </ul>

      <h2 class="font-display text-2xl font-semibold text-(--color-ink)">Related BMI calculators</h2>
      <nav class="flex flex-wrap gap-3">
        <a href="/" class="rounded-lg border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-sm text-(--color-link) hover:border-(--color-accent) transition">Adults</a>
        <a href="/bmi-calculator-for-women" class="rounded-lg border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-sm text-(--color-link) hover:border-(--color-accent) transition">Women</a>
        <a href="/bmi-calculator-for-men" class="rounded-lg border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-sm text-(--color-link) hover:border-(--color-accent) transition">Men</a>
        <a href="/bmi-chart" class="rounded-lg border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-sm text-(--color-link) hover:border-(--color-accent) transition">BMI Chart</a>
      </nav>
    </article>
  </div>
</BaseLayout>

<script>
// ── CDC BMI-for-age percentile lookup table ──────────────────────────────────
// P5, P85, P95 values for integer ages 2–20 by sex.
// Source: CDC 2000 Growth Charts (approximated for integer ages).
const CDC: Record<'male' | 'female', number[][]> = {
  // [age-2 index]: [P5, P85, P95]
  male: [
    [14.7, 17.4, 18.3], // 2
    [14.0, 16.9, 17.9], // 3
    [13.7, 16.7, 17.8], // 4
    [13.6, 16.9, 18.2], // 5
    [13.6, 17.3, 18.9], // 6
    [13.7, 17.9, 19.8], // 7
    [14.0, 18.7, 21.0], // 8
    [14.3, 19.5, 22.1], // 9
    [14.6, 20.3, 23.2], // 10
    [15.0, 21.2, 24.3], // 11
    [15.5, 22.1, 25.3], // 12
    [16.0, 22.9, 26.0], // 13
    [16.5, 23.6, 26.8], // 14
    [17.0, 24.2, 27.5], // 15
    [17.5, 24.7, 28.0], // 16
    [18.0, 25.2, 28.6], // 17
    [18.4, 25.7, 29.2], // 18
    [18.9, 26.2, 29.8], // 19
    [19.4, 26.7, 30.4], // 20
  ],
  female: [
    [14.5, 17.1, 18.0], // 2
    [13.8, 16.7, 17.7], // 3
    [13.5, 16.7, 17.8], // 4
    [13.4, 17.0, 18.3], // 5
    [13.4, 17.5, 19.1], // 6
    [13.6, 18.2, 20.2], // 7
    [13.9, 19.1, 21.6], // 8
    [14.3, 20.1, 23.0], // 9
    [14.7, 21.2, 24.3], // 10
    [15.2, 22.2, 25.5], // 11
    [15.7, 23.2, 26.8], // 12
    [16.2, 24.1, 27.8], // 13
    [16.8, 24.8, 28.5], // 14
    [17.3, 25.3, 29.0], // 15
    [17.7, 25.7, 29.4], // 16
    [18.0, 26.1, 29.7], // 17
    [18.3, 26.5, 30.2], // 18
    [18.7, 27.0, 30.7], // 19
    [19.0, 27.5, 31.1], // 20
  ],
};

/** Estimates BMI percentile from lookup table using linear interpolation between known thresholds. */
function estimatePercentile(bmi: number, p5: number, p85: number, p95: number): number {
  if (bmi < p5)  return Math.max(1,  Math.round(5  * (bmi / p5)));
  if (bmi < p85) return Math.round(5 + 80 * ((bmi - p5)  / (p85 - p5)));
  if (bmi < p95) return Math.round(85 + 10 * ((bmi - p85) / (p95 - p85)));
  // Above P95 — use extended linear estimate, cap display at 99
  return Math.min(99, Math.round(95 + 4 * ((bmi - p95) / (p95 * 0.15))));
}

function childCategory(pct: number): { label: string; color: string } {
  if (pct < 5)  return { label: 'Underweight',   color: '#3b82f6' };
  if (pct < 85) return { label: 'Healthy weight', color: '#10b981' };
  if (pct < 95) return { label: 'Overweight',     color: '#f59e0b' };
  return           { label: 'Obese',              color: '#ef4444' };
}

// ── Unit sync ─────────────────────────────────────────────────────────────────
const kgEl  = document.getElementById('child-weight-kg') as HTMLInputElement;
const lbEl  = document.getElementById('child-weight-lb') as HTMLInputElement;
const ftEl  = document.getElementById('child-height-ft') as HTMLInputElement;
const inEl  = document.getElementById('child-height-in') as HTMLInputElement;
const cmEl  = document.getElementById('child-height-cm') as HTMLInputElement;

kgEl?.addEventListener('input', () => {
  const kg = parseFloat(kgEl.value) || 0;
  lbEl.value = (kg * 2.20462).toFixed(1);
});
lbEl?.addEventListener('input', () => {
  const lb = parseFloat(lbEl.value) || 0;
  kgEl.value = (lb / 2.20462).toFixed(1);
});
ftEl?.addEventListener('input', () => {
  const ft = parseFloat(ftEl.value) || 0;
  const inch = parseFloat(inEl.value) || 0;
  cmEl.value = String(Math.round((ft * 12 + inch) * 2.54));
});
inEl?.addEventListener('input', () => {
  const ft = parseFloat(ftEl.value) || 0;
  const inch = parseFloat(inEl.value) || 0;
  cmEl.value = String(Math.round((ft * 12 + inch) * 2.54));
});
cmEl?.addEventListener('input', () => {
  const cm = parseFloat(cmEl.value) || 0;
  const totalIn = cm / 2.54;
  ftEl.value = String(Math.floor(totalIn / 12));
  inEl.value = String(Math.round(totalIn % 12));
});

// ── Calculate ─────────────────────────────────────────────────────────────────
document.getElementById('child-calc-btn')?.addEventListener('click', () => {
  const age    = parseInt((document.getElementById('child-age') as HTMLInputElement).value);
  const gEl    = document.querySelector('input[name="child-gender"]:checked') as HTMLInputElement;
  const sex    = (gEl?.value ?? 'male') as 'male' | 'female';
  const cm     = parseFloat(cmEl.value) || 0;
  const kg     = parseFloat(kgEl.value) || 0;

  if (isNaN(age) || age < 2 || age > 20 || cm <= 0 || kg <= 0) {
    alert('Please enter a valid age (2–20), height, and weight.');
    return;
  }

  const heightM = cm / 100;
  const bmi = kg / (heightM * heightM);
  const [p5, p85, p95] = CDC[sex][age - 2];
  const pct = estimatePercentile(bmi, p5, p85, p95);
  const cat = childCategory(pct);

  const bmiEl  = document.getElementById('child-bmi-value')!;
  const pctEl  = document.getElementById('child-percentile')!;
  const catEl  = document.getElementById('child-category')!;
  const mrkEl  = document.getElementById('child-marker')!;
  const detEl  = document.getElementById('child-details')!;
  const resEl  = document.getElementById('child-result')!;

  bmiEl.textContent = bmi.toFixed(1);
  pctEl.textContent = `${pct}th`;
  catEl.textContent = cat.label;
  catEl.style.backgroundColor = cat.color;
  mrkEl.style.left = `${Math.min(98, pct)}%`;

  const healthyLo = p5 * (heightM * heightM);
  const healthyHi = p85 * (heightM * heightM);
  detEl.innerHTML = [
    `BMI for age (${age}y ${sex === 'male' ? 'boy' : 'girl'}): <strong>${bmi.toFixed(1)}</strong>`,
    `Percentile: <strong>${pct}th</strong> — ${cat.label}`,
    `5th percentile BMI at this age: ${p5.toFixed(1)}`,
    `85th percentile BMI at this age: ${p85.toFixed(1)}`,
    `95th percentile BMI at this age: ${p95.toFixed(1)}`,
    `Healthy weight range for this height: ${healthyLo.toFixed(1)} – ${healthyHi.toFixed(1)} kg`,
  ].map(t => `<li>${t}</li>`).join('');

  resEl.classList.remove('hidden');
  resEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});
</script>
