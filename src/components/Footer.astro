---
const year = new Date().getFullYear();
const links = [
  { href: "/privacy-policy", label: "Privacy Policy" },
  { href: "/terms", label: "Terms" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
  { href: "/bmi-chart", label: "BMI Chart" },
  { href: "/blog", label: "Blog" },
  { href: "/embed", label: "Embed" },
];
---

<footer class="mt-16 border-t border-(--color-hairline) bg-(--color-surface)">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <nav class="mb-6 flex flex-wrap gap-4 text-sm" aria-label="Footer">
      {links.map((l) => (
        <a href={l.href} class="text-(--color-body) hover:text-(--color-link)">
          {l.label}
        </a>
      ))}
    </nav>
    <p class="text-sm text-(--color-mute)">
      © {year} BMI Result · bmiresult.com
    </p>
    <p class="mt-3 max-w-2xl text-xs leading-relaxed text-(--color-mute)">
      This BMI calculator is for educational purposes only and is not medical advice. Always consult a
      qualified healthcare provider about your weight and health.
    </p>
  </div>
</footer>