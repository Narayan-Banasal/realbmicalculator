---
import { BMI_CATEGORIES } from '../lib/bmi';
---

<section class="mt-16" aria-labelledby="visual-guide-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 id="visual-guide-heading" class="font-display text-2xl font-semibold text-(--color-ink) sm:text-3xl">
      What does your BMI look like?
    </h2>
    <p class="mt-2 max-w-2xl text-(--color-body)">
      Scroll through body-type guides (original illustrations — no stock licensing). Your active category
      highlights as you calculate. Tap a card to explore in 3D below.
    </p>

    <div
      id="visual-active-card"
      class="mt-8 flex flex-col items-center gap-4 rounded-2xl border border-(--color-hairline) bg-(--color-surface) p-6 sm:flex-row sm:gap-10"
    >
      <img
        id="visual-active-img"
        src="/images/bmi/normal.svg"
        alt="Active BMI category body guide"
        width="160"
        height="288"
        class="h-48 w-auto drop-shadow-lg transition-all duration-500"
      />
      <div>
        <p class="text-sm uppercase tracking-wide text-(--color-mute)">Your category</p>
        <p id="visual-active-label" class="font-display text-2xl font-semibold text-(--color-ink)">Normal weight</p>
        <p class="mt-2 text-sm text-(--color-body)">
          Illustrations show typical proportions — not medical imaging. Individual bodies vary widely.
        </p>
      </div>
    </div>

    <div
      class="gallery-track mt-8 flex gap-4 overflow-x-auto pb-4 scroll-smooth snap-x snap-mandatory"
      tabindex="0"
      aria-label="BMI category gallery — scroll horizontally"
    >
      {BMI_CATEGORIES.map((cat) => (
        <article
          data-gallery-card={cat.id}
          class="gallery-card w-[min(85vw,280px)] shrink-0 snap-center cursor-pointer rounded-2xl border border-(--color-hairline) bg-(--color-surface) p-5 opacity-50 transition-all duration-300 hover:opacity-100"
          style={`--cat-color: ${cat.color}`}
        >
          <div
            class="mx-auto flex h-40 w-32 items-end justify-center rounded-xl"
            style={`background: linear-gradient(180deg, ${cat.color}22, transparent)`}
          >
            <img
              src={`/images/bmi/${cat.id}.svg`}
              alt={`${cat.label} body guide illustration`}
              width="128"
              height="160"
              class="h-36 w-auto"
              loading="lazy"
            />
          </div>
          <h3 class="mt-4 font-semibold text-(--color-ink)">{cat.label}</h3>
          <p class="mt-1 text-xs font-medium" style={`color: ${cat.color}`}>
            BMI {cat.max === 60 ? `≥ ${cat.min}` : cat.min === 0 ? `< ${cat.max}` : `${cat.min} – ${cat.max}`}
          </p>
          <p class="mt-2 text-sm leading-relaxed text-(--color-body)">{cat.description}</p>
        </article>
      ))}
    </div>
    <p class="mt-3 text-center text-xs text-(--color-mute)">← Scroll sideways to compare categories →</p>
  </div>
</section>