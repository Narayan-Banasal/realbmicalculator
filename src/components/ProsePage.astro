---
interface Props {
  title: string;
  lead?: string;
}

const { title, lead } = Astro.props;
---

<article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
  <h1 class="font-display text-3xl font-bold text-(--color-ink) sm:text-4xl">{title}</h1>
  {lead && <p class="mt-4 text-lg text-(--color-body)">{lead}</p>}
  <div class="mt-8 space-y-4 text-(--color-body) leading-relaxed">
    <slot />
  </div>
</article>