---
import { BMI_CATEGORIES } from '../lib/bmi';
---

<section class="bmi-scene-section mt-20 overflow-hidden py-12" aria-labelledby="scene-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 id="scene-heading" class="font-display text-2xl font-semibold text-(--color-ink) sm:text-3xl">
      Explore BMI in 3D
    </h2>
    <p class="mt-2 max-w-2xl text-(--color-body)">
      Drag or scroll horizontally — cards tilt in 3D space. Updates automatically when your BMI changes.
    </p>
  </div>

  <div id="bmi-scene-3d" class="bmi-scene-stage mt-10">
    <div
      id="bmi-scene-track"
      class="bmi-scene-track flex gap-8 overflow-x-auto px-[max(1rem,calc(50vw-140px))] pb-12 pt-4 scroll-smooth snap-x snap-mandatory"
      style="perspective: 1200px;"
    >
      {BMI_CATEGORIES.map((cat) => (
        <article
          data-scene-card={cat.id}
          class={`bmi-scene-card snap-center ${cat.id === 'normal' ? 'is-active' : ''}`}
          style={`--card-accent: ${cat.color}`}
        >
          <div class="bmi-scene-card-inner">
            <span class="bmi-scene-badge" style={`background: ${cat.color}`}>
              {cat.shortLabel}
            </span>
            <img
              src={`/images/bmi/${cat.id}.svg`}
              alt=""
              width="140"
              height="252"
              class="mx-auto h-44 w-auto"
              loading="lazy"
            />
            <h3 class="mt-4 text-center font-display text-lg font-semibold text-(--color-ink)">{cat.label}</h3>
            <p class="mt-1 text-center text-sm font-medium" style={`color: ${cat.color}`}>
              Example BMI {cat.exampleBmi}
            </p>
            <p class="mt-3 text-center text-xs leading-relaxed text-(--color-body)">{cat.description}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="text-center text-xs text-(--color-mute)">Drag · scroll wheel · or tap gallery cards above</p>
  </div>
</section>

<script>
  import { initBmiScene3d } from '../scripts/bmi-scene-3d';
  initBmiScene3d();
</script>