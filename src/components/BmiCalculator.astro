---
---

<section
  id="bmi-calculator"
  class="rounded-2xl border border-(--color-hairline) bg-(--color-surface) p-5 shadow-sm sm:p-8"
  aria-labelledby="calc-heading"
>
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <h2 id="calc-heading" class="font-display text-xl font-semibold text-(--color-ink) sm:text-2xl">
        Calculate your BMI
      </h2>
      <p class="mt-1 text-sm text-(--color-body)">Sliders + precise inputs · instant sync</p>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs font-medium uppercase tracking-wide text-(--color-mute)">Units</span>
      <button
        type="button"
        id="unit-toggle"
        role="switch"
        aria-checked="false"
        aria-label="Switch between metric and US units"
        data-units="metric"
        class="unit-switch relative h-10 w-[5.5rem] rounded-full bg-(--color-hairline) p-1 transition"
      >
        <span class="absolute left-2 top-1/2 -translate-y-1/2 text-[10px] font-semibold text-(--color-body)">kg</span>
        <span class="absolute right-2 top-1/2 -translate-y-1/2 text-[10px] font-semibold text-(--color-body)">lb</span>
        <span
          id="unit-knob"
          class="unit-knob block h-8 w-[2.6rem] rounded-full bg-(--color-accent) shadow-md transition-transform"
        ></span>
      </button>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap gap-2" role="group" aria-label="Quick presets">
    <button type="button" data-preset="average" class="preset-chip">Average (BMI ~22)</button>
    <button type="button" data-preset="athlete" class="preset-chip">Athletic build</button>
  </div>

  <div class="mt-4 flex flex-wrap gap-4 rounded-xl bg-(--color-canvas) px-4 py-3 text-sm">
    <div>
      <span class="text-(--color-mute)">Height</span>
      <p id="display-height" class="font-semibold tabular-nums text-(--color-ink)">—</p>
    </div>
    <div>
      <span class="text-(--color-mute)">Weight</span>
      <p id="display-weight" class="font-semibold tabular-nums text-(--color-ink)">—</p>
    </div>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-2">
    <label class="block">
      <span class="text-sm font-medium text-(--color-body)">Age (optional)</span>
      <input
        type="number"
        id="age"
        min="2"
        max="120"
        placeholder="25"
        autocomplete="off"
        class="mt-1 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-4 py-3 outline-none focus:border-(--color-accent) focus:ring-2 focus:ring-(--color-accent)/20"
      />
    </label>
    <fieldset class="block">
      <legend class="text-sm font-medium text-(--color-body)">Gender (optional)</legend>
      <div class="mt-2 flex gap-2">
        <label class="flex flex-1 cursor-pointer items-center justify-center rounded-xl border border-(--color-hairline) px-3 py-3 has-checked:border-(--color-accent) has-checked:bg-(--color-accent)/10">
          <input type="radio" name="gender" value="female" class="sr-only" />
          <span class="text-sm">Female</span>
        </label>
        <label class="flex flex-1 cursor-pointer items-center justify-center rounded-xl border border-(--color-hairline) px-3 py-3 has-checked:border-(--color-accent) has-checked:bg-(--color-accent)/10">
          <input type="radio" name="gender" value="male" class="sr-only" checked />
          <span class="text-sm">Male</span>
        </label>
      </div>
    </fieldset>
  </div>

  <div id="height-metric" class="mt-6 space-y-6">
    <div>
      <div class="flex items-center justify-between gap-2">
        <label for="height-cm" class="text-sm font-medium text-(--color-body)">Height (cm)</label>
        <div class="flex gap-1">
          <button type="button" data-nudge="height-cm" data-delta="-1" class="nudge-btn" aria-label="Decrease height">−</button>
          <button type="button" data-nudge="height-cm" data-delta="1" class="nudge-btn" aria-label="Increase height">+</button>
        </div>
      </div>
      <input type="range" id="height-cm-range" min="100" max="250" value="170" class="bmi-range mt-2" />
      <input
        type="number"
        id="height-cm"
        min="100"
        max="250"
        value="170"
        autocomplete="off"
        class="mt-2 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-lg tabular-nums outline-none focus:border-(--color-accent)"
      />
    </div>
    <div>
      <div class="flex items-center justify-between gap-2">
        <label for="weight-kg" class="text-sm font-medium text-(--color-body)">Weight (kg)</label>
        <div class="flex gap-1">
          <button type="button" data-nudge="weight-kg" data-delta="-0.5" class="nudge-btn">−0.5</button>
          <button type="button" data-nudge="weight-kg" data-delta="0.5" class="nudge-btn">+0.5</button>
          <button type="button" data-nudge="weight-kg" data-delta="1" class="nudge-btn">+1</button>
        </div>
      </div>
      <input type="range" id="weight-kg-range" min="30" max="350" step="0.5" value="70" class="bmi-range mt-2" />
      <input
        type="number"
        id="weight-kg"
        min="30"
        max="400"
        step="0.1"
        value="70"
        autocomplete="off"
        class="mt-2 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-lg tabular-nums outline-none focus:border-(--color-accent)"
      />
    </div>
  </div>

  <div id="height-us" class="mt-6 hidden space-y-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <div class="flex items-center justify-between">
          <label for="height-ft" class="text-sm font-medium text-(--color-body)">Feet</label>
          <button type="button" data-nudge="height-ft" data-delta="-1" class="nudge-btn">−</button>
        </div>
        <input type="range" id="height-ft-range" min="4" max="9" value="5" class="bmi-range mt-2" />
        <input type="number" id="height-ft" min="4" max="9" value="5" autocomplete="off" class="mt-2 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-lg" />
      </div>
      <div>
        <div class="flex items-center justify-between">
          <label for="height-in" class="text-sm font-medium text-(--color-body)">Inches</label>
          <button type="button" data-nudge="height-in" data-delta="1" class="nudge-btn">+</button>
        </div>
        <input type="range" id="height-in-range" min="0" max="11" value="10" class="bmi-range mt-2" />
        <input type="number" id="height-in" min="0" max="11" value="10" autocomplete="off" class="mt-2 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-lg" />
      </div>
    </div>
    <div>
      <div class="flex items-center justify-between gap-2">
        <label for="weight-lb" class="text-sm font-medium text-(--color-body)">Weight (lb)</label>
        <div class="flex gap-1">
          <button type="button" data-nudge="weight-lb" data-delta="-1" class="nudge-btn">−1</button>
          <button type="button" data-nudge="weight-lb" data-delta="1" class="nudge-btn">+1</button>
          <button type="button" data-nudge="weight-lb" data-delta="5" class="nudge-btn">+5</button>
        </div>
      </div>
      <input type="range" id="weight-lb-range" min="80" max="880" step="0.5" value="160" class="bmi-range mt-2" />
      <input
        type="number"
        id="weight-lb"
        min="80"
        max="900"
        step="0.1"
        value="160"
        autocomplete="off"
        class="mt-2 w-full rounded-xl border border-(--color-hairline) bg-(--color-canvas) px-4 py-2 text-lg tabular-nums"
      />
    </div>
  </div>

  <div class="mt-6">
    <h3 class="text-sm font-medium text-(--color-body) mb-1">Your Body Visualization <span class="text-[10px] text-(--color-mute)">(live 3D model • drag to rotate • updates with height &amp; weight)</span></h3>
    <div id="body-model-container" class="mx-auto relative overflow-hidden rounded-2xl border border-(--color-hairline) bg-(--color-canvas)" style="width:320px; height:400px;">
      <canvas id="body-canvas" width="320" height="400" class="block touch-none" style="width:320px; height:400px;"></canvas>
    </div>
    <p id="body-status" class="text-center text-xs text-(--color-mute) mt-1"></p>
  </div>

  <div id="result-panel" class="mt-8 hidden">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-sm uppercase tracking-wide text-(--color-mute)">Your BMI</p>
        <p id="bmi-value" class="font-display text-5xl font-bold tabular-nums text-(--color-ink)">—</p>
      </div>
      <span id="bmi-category" class="rounded-full px-4 py-1.5 text-sm font-semibold text-white"></span>
    </div>

    <div class="relative mt-6 h-4 overflow-hidden rounded-full bg-(--color-hairline)">
      <div class="absolute inset-0 flex">
        <div class="h-full w-[18.5%] bg-(--color-under)"></div>
        <div class="h-full w-[6.4%] bg-(--color-normal)"></div>
        <div class="h-full w-[5%] bg-(--color-over)"></div>
        <div class="h-full flex-1 bg-(--color-obese)"></div>
      </div>
      <div
        id="bmi-marker"
        class="absolute top-1/2 h-6 w-6 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-(--color-ink) shadow-lg transition-all duration-500"
        style="left: 0%"
      ></div>
    </div>
    <div class="mt-2 flex justify-between text-[10px] text-(--color-mute) sm:text-xs">
      <span>16</span><span>18.5</span><span>25</span><span>30</span><span>40+</span>
    </div>

    <ul id="result-details" class="mt-6 space-y-2 text-sm text-(--color-body)"></ul>

    <button type="button" id="copy-result" class="mt-4 text-sm font-medium text-(--color-link) hover:underline">
      Copy result link
    </button>
  </div>
</section>

<script>
  import { initBmiCalculator } from '../scripts/bmi-calculator';
  initBmiCalculator();
</script>

<style>
  .unit-switch[aria-checked='true'] .unit-knob {
    transform: translateX(2.5rem);
  }
  .unit-switch[aria-checked='false'] .unit-knob {
    transform: translateX(0);
  }
  .nudge-btn {
    border-radius: 0.5rem;
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-ink);
    transition: border-color 0.15s, background 0.15s;
  }
  .nudge-btn:hover {
    border-color: var(--color-accent);
    background: color-mix(in oklch, var(--color-accent) 12%, var(--color-canvas));
  }
  .bmi-range {
    margin-top: 0.5rem;
    height: 0.5rem;
    width: 100%;
    cursor: pointer;
    appearance: none;
    border-radius: 9999px;
    background: var(--color-hairline);
    accent-color: var(--color-accent);
  }
  .preset-chip {
    border-radius: 9999px;
    border: 1px solid var(--color-hairline);
    background: var(--color-canvas);
    padding: 0.35rem 0.85rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-body);
    transition: border-color 0.15s, color 0.15s;
  }
  .preset-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-ink);
  }
</style>