---
const nav = [
  { href: "/", label: "BMI Calculator" },
  { href: "/bmi-chart", label: "BMI Chart" },
  { href: "/bmi-calculator-for-women", label: "For Women" },
  { href: "/bmi-calculator-for-men", label: "For Men" },
  { href: "/about", label: "About" },
];
const legal = [
  { href: "/privacy-policy", label: "Privacy" },
  { href: "/terms", label: "Terms" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-(--color-hairline) bg-(--color-surface)/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3 sm:px-6">
    <a href="/" class="font-display text-lg font-semibold tracking-tight text-(--color-ink) sm:text-xl">
      Real BMI Calculator
    </a>
    <nav class="flex flex-wrap items-center gap-1 text-sm" aria-label="Main">
      {nav.map((item) => (
        <a
          href={item.href}
          class="rounded-lg px-2.5 py-1.5 text-(--color-body) transition hover:bg-(--color-canvas) hover:text-(--color-ink)"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <nav class="hidden items-center gap-1 text-xs sm:flex" aria-label="Legal">
        {legal.map((item) => (
          <a href={item.href} class="text-(--color-mute) hover:text-(--color-link)">
            {item.label}
          </a>
        ))}
      </nav>
      <button
        type="button"
        id="theme-toggle"
        class="rounded-lg border border-(--color-hairline) bg-(--color-canvas) px-3 py-1.5 text-sm font-medium text-(--color-ink) transition hover:border-(--color-accent)"
        aria-label="Toggle dark mode"
      >
        <span class="dark:hidden">Dark</span>
        <span class="hidden dark:inline">Light</span>
      </button>
    </div>
  </div>
</header>

<script>
  const key = "rbmi-theme";
  const root = document.documentElement;

  const stored = localStorage.getItem(key);
  if (stored === "dark") {
    root.classList.add("dark");
  }

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    root.classList.toggle("dark");
    localStorage.setItem(key, root.classList.contains("dark") ? "dark" : "light");
  });
</script>