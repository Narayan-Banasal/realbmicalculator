---
const nav = [
  { href: "/", label: "BMI Calculator" },
  { href: "/bmi-chart", label: "BMI Chart" },
  { href: "/bmi-calculator-for-women", label: "For Women" },
  { href: "/bmi-calculator-for-men", label: "For Men" },
  { href: "/about", label: "About" },
];
const legal = [
  { href: "/privacy-policy", label: "Privacy" },
  { href: "/terms", label: "Terms" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-(--color-hairline) bg-(--color-surface)/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3 sm:px-6">
    <a href="/" class="font-display text-lg font-semibold tracking-tight text-(--color-ink) sm:text-xl">
      Real BMI Calculator
    </a>
    <nav class="flex flex-wrap items-center gap-1 text-sm" aria-label="Main">
      {nav.map((item) => (
        <a
          href={item.href}
          class="rounded-lg px-2.5 py-1.5 text-(--color-body) transition hover:bg-(--color-canvas) hover:text-(--color-ink)"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <nav class="hidden items-center gap-1 text-xs sm:flex" aria-label="Legal">
        {legal.map((item) => (
          <a href={item.href} class="text-(--color-mute) hover:text-(--color-link)">
            {item.label}
          </a>
        ))}
      </nav>
      <!-- Theme dropdown: default white/light as requested. Easy toggle to dark or system. Keeps UI simple & personal. Good idea for accessibility & preference (per design guidelines). -->
      <label class="text-xs text-(--color-mute) hidden sm:inline">Theme</label>
      <select id="theme-select" class="rounded-lg border border-(--color-hairline) bg-(--color-canvas) px-2 py-1 text-sm text-(--color-ink) focus:border-(--color-accent) focus:ring-1 focus:ring-(--color-accent)/30" aria-label="Choose color theme">
        <option value="light">Light (default)</option>
        <option value="dark">Dark</option>
        <option value="system">System</option>
      </select>
    </div>
  </div>
</header>

<script>
  const key = "rbmi-theme";
  const root = document.documentElement;
  const sel = document.getElementById("theme-select") as HTMLSelectElement | null;

  function applyTheme(mode: string) {
    root.classList.remove("dark");
    if (mode === "dark" || (mode === "system" && matchMedia("(prefers-color-scheme: dark)").matches)) {
      root.classList.add("dark");
    }
    if (sel) sel.value = mode;
  }

  const stored = localStorage.getItem(key) || "light";
  applyTheme(stored);

  if (sel) {
    sel.addEventListener("change", () => {
      const mode = sel.value;
      localStorage.setItem(key, mode);
      applyTheme(mode);
    });
  }

  // respect system changes if "system" selected
  matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
    if (localStorage.getItem(key) === "system") applyTheme("system");
  });
</script>